---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="playground - incomplete.fun">
  <div class="canvas-app" id="playground-app">
    <div class="topbar">
      <a class="back-link" href="/" aria-label="Back to home">←</a>
      <span><strong>playground</strong></span>
      <span style="color: var(--border);">|</span>
      <button class="shape-btn" data-figure="box" title="square block" type="button">□</button>
      <button class="shape-btn" data-figure="plank" title="horizontal plank" type="button">▬</button>
      <button class="shape-btn" data-figure="circle" title="circle" type="button">○</button>
      <button class="shape-btn" data-figure="triangle" title="triangle" type="button">△</button>
      <button class="shape-btn" data-figure="spiral" title="spiral" type="button">↺</button>
      <span id="playground-status">click to place · right-click removes</span>
      <button class="toolbar-button" id="playground-clear" type="button">clear</button>
      <button class="toolbar-button" id="playground-launch" type="button">launch</button>
    </div>
    <div class="canvas-stage" style="cursor: crosshair;">
      <canvas id="playground-canvas" style="display: block; width: 100%; height: 100%;"></canvas>
    </div>
  </div>
</BaseLayout>

<style>
  #playground-app {
    background: #080a2a;
  }

  #playground-status {
    color: #d9e0ff;
    margin-left: auto;
    font-size: 0.8rem;
  }

  .shape-btn {
    background: none;
    border: 1px solid #3a4a8f;
    color: #d9e0ff;
    font-family: var(--mono);
    font-size: 1rem;
    width: 2rem;
    height: 1.6rem;
    padding: 0;
    cursor: pointer;
    border-radius: 4px;
    line-height: 1;
  }

  #playground-clear {
    color: #d9e0ff;
    border-color: #3a4a8f;
  }

  #playground-launch {
    color: #d9e0ff;
    border-color: #3a4a8f;
    background: rgba(46, 92, 255, 0.15);
  }

  #playground-launch:not(:disabled):hover {
    background: rgba(46, 92, 255, 0.3);
  }

  #playground-launch:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
</style>

<script>
  import '../scripts/playground.ts';
</script>
