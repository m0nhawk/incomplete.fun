---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="escape - incomplete.fun">
  <div class="canvas-app canvas-app-dark" id="escape-app">
    <div class="topbar">
      <a class="back-link" href="/" aria-label="Back to home">←</a>
      <span><strong>escape</strong></span>
      <span style="color: var(--border);">|</span>
      <label class="control" for="escape-rings-input">
        rings
        <input id="escape-rings-input" type="number" min="1" max="12" step="1" value="5" />
      </label>
      <label class="control" for="escape-speed-input">
        speed
        <input id="escape-speed-input" type="number" min="1" max="20" step="0.5" value="9" />
      </label>
      <span class="status-text" id="escape-status">rings: 0</span>
      <button class="toolbar-button" id="escape-reset" type="button">randomize</button>
    </div>
    <div class="canvas-stage">
      <canvas id="escape-canvas" style="display: block; width: 100%; height: 100%;"></canvas>
    </div>
  </div>
</BaseLayout>

<script>
  import '../scripts/escape.ts';
</script>
