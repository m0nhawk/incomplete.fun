  name='Snapshot export metadata'
  summary='Embed title, parameters, seed, and short explanations beside saved SVG or PNG outputs.'
  kind='extension'
  controls={['title', 'seed', 'annotation']}
  invariants={['metadata fields', 'export size', 'caption length', 'parameter count']}
