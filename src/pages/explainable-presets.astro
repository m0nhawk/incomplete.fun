---
import IdeaExperiment from '../components/IdeaExperiment.astro';
---

<IdeaExperiment
  name='Random explainable presets'
  summary='Generate interesting random states and list the properties that make each generated configuration worth exploring.'
  kind='extension'
  controls={['randomness', 'constraint', 'explanation']}
  invariants={['property count', 'rarity score', 'seed hash', 'explanation length']}
  related={[{ href: '/', label: 'gallery' }, { href: '/complex', label: 'complex' }]}
/>
