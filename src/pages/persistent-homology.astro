---
import IdeaExperiment from '../components/IdeaExperiment.astro';
---

<IdeaExperiment
  name='Persistent homology sandbox'
  summary='Drop points, grow balls, and plot Betti numbers and barcode intervals as components merge and loops appear.'
  kind='math'
  controls=['ball radius', 'point seed', 'noise']
  invariants=['β₀ components', 'β₁ loops', 'longest bar', 'merge scale']
  related=[{ href: '/voronoi', label: 'voronoi' }, { href: '/spectral', label: 'spectral' }]
/>
