---
import IdeaExperiment from '../components/IdeaExperiment.astro';
---

<IdeaExperiment
  name='Shared preset URLs'
  summary='Encode experiment parameters into bookmarkable links so compact canvas states can be saved, shared, and revisited.'
  kind='extension'
  controls={['parameter pack', 'seed', 'URL length']}
  invariants={['encoded state', 'checksum', 'share size', 'restore status']}
  related={[{ href: '/', label: 'gallery' }, { href: '/reaction-diffusion', label: 'canvas lab' }]}
/>
