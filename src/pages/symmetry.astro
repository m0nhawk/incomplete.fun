---
import CanvasLayout from '../layouts/CanvasLayout.astro';
---

<CanvasLayout name="symmetry" appId="symmetry-app">
  <Fragment slot="toolbar">
    <label class="control-label">
      n=
      <input id="symmetry-segments" type="number" min="1" max="36" value="6" />
    </label>

    <label class="control-label symmetry-check">
      <input id="symmetry-mirror" type="checkbox" />
      mirror
    </label>

    <label class="control-label">
      color
      <input id="symmetry-color" type="color" value="#4d9fff" />
    </label>

    <label class="control-label">
      width
      <input id="symmetry-width" type="range" min="1" max="20" value="2" />
      <span id="symmetry-width-value">2</span>
    </label>

    <button class="toolbar-button" id="symmetry-clear" type="button">clear</button>
  </Fragment>

  <div class="canvas-stage">
    <canvas id="symmetry-canvas"></canvas>
  </div>
</CanvasLayout>

<style>
  .symmetry-check { cursor: pointer; }

  #symmetry-segments { width: 3rem; }
  #symmetry-width { width: 5rem; }

  #symmetry-width-value {
    color: var(--muted);
    min-width: 1.5rem;
  }

  #symmetry-canvas {
    display: block;
    width: 100%;
    height: 100%;
    cursor: crosshair;
    touch-action: none;
  }
</style>

<script>
  import '../scripts/symmetry.ts';
</script>
