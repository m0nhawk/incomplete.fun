---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout name="spectral graph playground" back wide>
  <p class="spectral-intro">Generate small graphs, inspect adjacency or Laplacian spectra, and watch one eigenmode push the nodes along its vibration pattern.</p>

  <section class="spectral-grid" id="spectral-app">
    <article class="spectral-card spectral-controls">
      <label>
        graph
        <select id="spectral-graph">
          <option value="cycle">cycle</option>
          <option value="path">path</option>
          <option value="star">star</option>
          <option value="wheel">wheel</option>
          <option value="complete">complete</option>
          <option value="grid">grid</option>
        </select>
      </label>
      <label>
        size
        <input id="spectral-size" type="number" min="3" max="24" value="10" />
      </label>
      <label>
        matrix
        <select id="spectral-matrix">
          <option value="laplacian">laplacian</option>
          <option value="adjacency">adjacency</option>
        </select>
      </label>
      <label>
        mode
        <input id="spectral-mode" type="range" min="0" max="9" value="1" />
        <span id="spectral-mode-value">1</span>
      </label>
    </article>

    <article class="spectral-card spectral-wide">
      <div class="spectral-head">
        <div>
          <h2>eigenmode layout</h2>
          <p id="spectral-summary" class="spectral-muted" aria-live="polite"></p>
        </div>
        <button class="toolbar-button" id="spectral-wobble" type="button">pause wobble</button>
      </div>
      <div class="spectral-svg-wrap">
        <svg id="spectral-plot" role="img" aria-label="Graph eigenmode visualization"></svg>
      </div>
    </article>

    <article class="spectral-card">
      <h2>spectrum</h2>
      <div id="spectral-values" class="spectral-values"></div>
    </article>

    <article class="spectral-card">
      <h2>mode vector</h2>
      <div id="spectral-vector" class="spectral-values"></div>
    </article>
  </section>
</PageLayout>

<style>
  .spectral-intro,
  .spectral-muted,
  .spectral-card label,
  .spectral-values { color: var(--muted); }

  .spectral-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 22rem), 1fr));
    gap: 1rem;
  }

  .spectral-wide { grid-column: 1 / -1; }

  .spectral-card {
    border: 1px solid var(--line);
    padding: 1rem;
    min-width: 0;
  }

  .spectral-card h2 {
    font-size: 1rem;
    margin: 0 0 .5rem;
  }

  .spectral-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    gap: .75rem 1rem;
  }

  .spectral-controls label {
    display: grid;
    gap: .25rem;
  }

  .spectral-controls input[type="number"] {
    width: 4.5rem;
    padding: .25rem .4rem;
  }

  .spectral-controls input[type="range"] { width: 7rem; }

  #spectral-mode-value {
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  .spectral-head {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .spectral-svg-wrap {
    border: 1px solid var(--line);
    background: var(--wash);
    overflow: auto;
  }

  #spectral-plot {
    display: block;
    width: 100%;
    min-width: 38rem;
    height: 30rem;
  }

  .spectral-values {
    display: grid;
    gap: .25rem;
    font-variant-numeric: tabular-nums;
    overflow-x: auto;
  }
</style>

<style is:global>
  .spectral-edge { stroke: var(--line); stroke-width: 2; }
  .spectral-edge.is-strong { stroke: var(--fg); }
  .spectral-node { fill: var(--bg); stroke: var(--fg); stroke-width: 1.5; }
  .spectral-node.is-positive { fill: color-mix(in srgb, var(--fg) 18%, var(--bg)); }
  .spectral-node.is-negative { fill: color-mix(in srgb, var(--fg) 7%, var(--bg)); }
  .spectral-label { fill: var(--muted); font: 11px ui-monospace, monospace; }
  .spectral-bar { display: grid; grid-template-columns: 4rem 1fr 4rem; gap: .5rem; align-items: center; }
  .spectral-bar-track { height: .45rem; background: var(--wash); border: 1px solid var(--line); }
  .spectral-bar-fill { height: 100%; background: var(--fg); }
</style>

<script>
  import '../scripts/spectral.ts';
</script>
